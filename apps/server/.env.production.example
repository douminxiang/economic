# ===== 数据库 =====
DATABASE_URL="mysql://root:${DB_PASSWORD}@db:3306/economic"

# ===== JWT 认证（生产环境必须修改！）=====
JWT_SECRET="replace-with-a-strong-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="replace-with-another-strong-random-string"
JWT_REFRESH_EXPIRES_IN="7d"
SSO_SINGLE_SESSION="true"

# ===== 服务配置 =====
PORT=3000
NODE_ENV=production
# 生产环境公网访问地址（用于回调 URL 等）
PUBLIC_BASE_URL="https://your-domain.com"

# ===== 高德地图 =====
AMAP_WEB_KEY="your-amap-web-service-key"

# ===== AI（SiliconFlow API Key）=====
ANTHROPIC_API_KEY="sk-your-siliconflow-api-key"
AI_VISION_MODEL="Qwen/Qwen3-VL-8B-Instruct"

# ===== OSS 文件存储（阿里云 OSS）=====
OSS_REGION="oss-cn-hangzhou"
OSS_BUCKET="your-bucket-name"
OSS_ACCESS_KEY_ID="your-access-key-id"
OSS_ACCESS_KEY_SECRET="your-access-key-secret"
OSS_PUBLIC_BASE_URL="https://your-cdn-domain.com"

# ===== 支付宝（生产环境）=====
ALIPAY_APP_ID="your-app-id"
ALIPAY_PRIVATE_KEY="your-private-key"
ALIPAY_PUBLIC_KEY="your-alipay-public-key"
ALIPAY_NOTIFY_URL="https://your-domain.com/api/pay/notify"
ALIPAY_GATEWAY="https://openapi.alipay.com/gateway.do"
ALIPAY_SIGN_TYPE="RSA2"
ALIPAY_KEY_TYPE="PKCS1"
ALIPAY_RETURN_URL="https://your-domain.com/payment/result"

# ===== 短信验证码（阿里云短信）=====
SMS_ACCESS_KEY_ID="your-access-key-id"
SMS_ACCESS_KEY_SECRET="your-access-key-secret"
SMS_SIGN_NAME="你的签名"
SMS_TEMPLATE_CODE="SMS_xxxxxx"

# ===== Sentry 监控（可选）=====
SENTRY_DSN="your-sentry-dsn"
SENTRY_ENVIRONMENT="production"
SENTRY_TRACES_SAMPLE_RATE=0.1
