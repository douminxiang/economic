# === 数据库 ===
DATABASE_URL="mysql://root:root@localhost:3306/economic"

# === JWT 认证 ===
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# === 服务配置 ===
PORT=3000
# 移动端可访问的后端地址（Android 模拟器用 10.0.2.2，真机用电脑局域网 IP）
PUBLIC_BASE_URL="http://10.0.2.2:3000"

# === 高德地图（Web 服务 Key，用于后端 REST API 代理）===
AMAP_WEB_KEY="your-amap-web-service-key"

# === AI（SiliconFlow API Key）===
ANTHROPIC_API_KEY="sk-your-siliconflow-api-key"

# === OSS 文件存储（留空为 mock 模式，文件存本地 uploads/）===
OSS_REGION=""
OSS_BUCKET=""
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""

# === 支付宝（留空为 mock 模式）===
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""
ALIPAY_PUBLIC_KEY=""
# 本地开发时 ALIPAY_NOTIFY_URL 可为 10.0.2.2；沙箱实际使用下方占位 HTTPS 回调
ALIPAY_SANDBOX_NOTIFY_URL="https://www.taobao.com/notify"
ALIPAY_GATEWAY="https://openapi-sandbox.dl.alipaydev.com/gateway.do"
ALIPAY_SIGN_TYPE="RSA2"
ALIPAY_KEY_TYPE="PKCS1"
# 支付完成后浏览器跳转（沙箱可填任意 https 地址）
ALIPAY_RETURN_URL="https://www.taobao.com"

# === 短信（留空为 mock 模式，验证码打印到后端控制台）===
SMS_ACCESS_KEY_ID=""
SMS_ACCESS_KEY_SECRET=""
SMS_SIGN_NAME=""
SMS_TEMPLATE_CODE=""

# === Sentry 监控（可选）===
SENTRY_DSN=""
SENTRY_DSN_MOBILE=""
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE=0.2
