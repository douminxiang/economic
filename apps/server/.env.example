# === 数据库 ===
DATABASE_URL="mysql://root:root@localhost:3306/economic"
# MySQL 会话时区（埋点/订单等 createdAt 写入北京时间，默认东八区）
DB_TIMEZONE="+08:00"

# === JWT 认证 ===
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-me-refresh-secret"
# 单点登录：true 时新登录会踢掉其他设备（默认 true）
SSO_SINGLE_SESSION="true"

# === 服务配置 ===
PORT=3000
# 移动端可访问的后端地址（Android 模拟器用 10.0.2.2，真机用电脑局域网 IP）
PUBLIC_BASE_URL="http://10.0.2.2:3000"

# === 高德地图（Web 服务 Key，用于后端 REST API 代理）===
AMAP_WEB_KEY="your-amap-web-service-key"

# === AI（SiliconFlow API Key）===
ANTHROPIC_API_KEY="sk-your-siliconflow-api-key"
# 多模态图片理解模型（SiliconFlow，默认 Qwen/Qwen3-VL-8B-Instruct）
AI_VISION_MODEL="Qwen/Qwen3-VL-8B-Instruct"

# === OSS 文件存储（四项全填才启用阿里云 OSS，否则存本地 uploads/）===
# 控制台：对象存储 OSS → Bucket 列表 → 创建 Bucket → 读写权限建议「公共读」
# AI 多模态对话图片必须通过 POST /upload/image/ai 写入 OSS（未配置 OSS 时无法发图）
OSS_REGION="oss-cn-hangzhou"
OSS_BUCKET="your-bucket-name"
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
# 可选：自定义域名或 CDN 前缀，不填则用 OSS 默认公网 URL
# OSS_ENDPOINT="https://oss-cn-hangzhou.aliyuncs.com"
OSS_PUBLIC_BASE_URL=""

# === 支付宝（留空为 mock 模式）===
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""
ALIPAY_PUBLIC_KEY=""
# 本地开发时 ALIPAY_NOTIFY_URL 可为 10.0.2.2；沙箱实际使用下方占位 HTTPS 回调
ALIPAY_SANDBOX_NOTIFY_URL="https://www.taobao.com/notify"
ALIPAY_GATEWAY="https://openapi-sandbox.dl.alipaydev.com/gateway.do"
ALIPAY_SIGN_TYPE="RSA2"
ALIPAY_KEY_TYPE="PKCS1"
# 支付完成后浏览器跳转（沙箱可填任意 https 地址）
ALIPAY_RETURN_URL="https://www.taobao.com"

# === 短信验证码（四项全填才发真实短信，否则验证码打印到后端控制台）===
# 控制台：短信服务 → 签名管理 + 模板管理（模板变量须含 ${code}）
# AccessKey：RAM 用户需 AliyunDysmsFullAccess 权限
SMS_ACCESS_KEY_ID=""
SMS_ACCESS_KEY_SECRET=""
SMS_SIGN_NAME="你的签名"
SMS_TEMPLATE_CODE="SMS_xxxxxx"

# === Sentry 监控（可选）===
SENTRY_DSN=""
SENTRY_DSN_MOBILE=""
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE=0.2
